import os

DATABASE_URI = os.getenv('DATABASE_URI', 'sqlite:///:memory:')

BASE_API_URL = "https:///api/v1"
LOGIN_API_URL = f"{BASE_API_URL}/auth/login"
PRODUCTS_BASE_API_URL = f"{BASE_API_URL}/products"

# ---

import pytest
from app import create_app
from extensions import db
import logging

logger = logging.getLogger(__name__)
logger.setLevel(logging.INFO)
handler = logging.StreamHandler()
handler.setFormatter(logging.Formatter('%(asctime)s - %(name)s - %(levelname)s - %(message)s'))
logger.addHandler(handler)


@pytest.fixture(scope="function")
def test_app():
    """
    Fixture for creating a test Flask app with an in-memory SQLite database.
    This runs before and after each test function.
    """
    app = create_app({
        'SQLALCHEMY_DATABASE_URI': DATABASE_URI,
        'TESTING': True,
        'SQLALCHEMY_TRACK_MODIFICATIONS': False,
        'JWT_SECRET_KEY': 'test-secret-key',

        # 'PREFERRED_URL_SCHEME': 'https',
    })

    with app.app_context():
        db.create_all()

        # --- SQLite-Specific Setup ---
        # This block is required only for SQLite in-memory databases.
        from sqlalchemy import text
        with db.engine.connect() as conn:
            conn.execute(text("PRAGMA foreign_keys = ON"))
            conn.commit()

        yield app

        db.drop_all()


@pytest.fixture(scope="function")
def db_session():
    """
    Ensures each test runs in an isolated database transaction.
    """
    db.session.begin(subtransactions=True)
    yield db.session
    db.session.rollback()


@pytest.fixture(scope="function")
def client(test_app):
    """
    Create a test client for the Flask app.
    This allows making HTTP requests to the app during testing.
    This runs once per test module.
    """
    with test_app.test_client() as client:
        yield client



from tests.factories import UserFactory
import common.status_codes as status

@pytest.fixture
def helper_make_request(client):
    def _make_request(method, path, *args, role_name=None, **kwargs):
        access_token = None
        user = None

        from models.user import Role

        if role_name:
            role_obj = Role.query.filter_by(name=role_name).first()
            if not role_obj:
                raise ValueError(f"Role '{role_name}' not found in the database.")

            user = UserFactory()
            user.set_password('test_pass')
            user.role = role_obj

            db.session.add(user)
            db.session.commit()

            login_response = client.post(LOGIN_API_URL, json={'email': user.email, 'password': 'test_pass'})
            assert login_response.status_code == status.HTTP_200_OK
            access_token = login_response.get_json()['access_token']

        headers = {"Authorization": f"Bearer {access_token}"} if role_name else {}

        try:
            return client.open(path, method=method, headers=headers, *args, **kwargs)
        finally:
            if user:
                db.session.delete(user)
                db.session.commit()

    return _make_request
